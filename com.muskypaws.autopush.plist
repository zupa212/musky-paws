<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.muskypaws.autopush</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/xupi/GIT/musky-paws/scripts/auto-push.sh</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/xupi/GIT/musky-paws</string>

    <key>RunAtLoad</key>
    <true/>

    <key>StartInterval</key>
    <integer>180</integer>

    <key>StandardOutPath</key>
    <string>/tmp/musky-paws-autopush-launchd-out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/musky-paws-autopush-launchd-err.log</string>
</dict>
</plist>
